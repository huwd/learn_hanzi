<% colour = case state
            when "pending"  then "bg-yellow-100 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-400"
            when "running"  then "bg-blue-100 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400"
            when "complete" then "bg-green-100 dark:bg-green-900/20 text-green-700 dark:text-green-400"
            when "failed"   then "bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-400"
            else                 "bg-gray-100 dark:bg-gray-800 text-gray-500"
            end %>
<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= colour %>">
  <%= state %>
</span>
