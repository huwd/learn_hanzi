<h1>Import Anki Collection</h1>

<%= form_with url: admin_anki_imports_path, multipart: true do |f| %>
  <div>
    <%= f.label :file, "Anki collection file (.anki21 or .apkg)" %>
    <%= f.file_field :file, accept: ".anki21,.apkg,.colpkg" %>
  </div>
  <%= f.submit "Import" %>
<% end %>

<% if @recent_imports.any? %>
  <h2>Recent imports</h2>
  <ul>
    <% @recent_imports.each do |import| %>
      <li>
        <%= link_to import.created_at.to_fs(:short), admin_anki_import_path(import) %>
        — <%= import.state %>
        <% if import.complete? %>
          (<%= import.cards_imported %> cards, <%= import.review_logs_imported %> review logs)
        <% end %>
        <% if import.failed? %>
          — Error: <%= import.error_message %>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>
