<div class="flex flex-col items-center justify-center text-center max-w-md mx-auto">
  <h2 class="text-3xl font-bold text-gray-800 dark:text-gray-200 mb-8">Session complete</h2>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow p-8 w-full mb-8">
    <p class="text-5xl font-bold text-gray-800 dark:text-gray-200 mb-2"><%= @total %></p>
    <p class="text-gray-500 dark:text-gray-400">cards reviewed</p>

    <% if @review_logs.any? %>
      <dl class="mt-6 grid grid-cols-4 gap-4 text-center">
        <% { "Again" => 1, "Hard" => 2, "Good" => 3, "Easy" => 4 }.each do |label, ease| %>
          <div>
            <dt class="text-xs text-gray-400"><%= label %></dt>
            <dd class="text-xl font-semibold text-gray-800 dark:text-gray-200"><%= @review_logs.count { |r| r.ease == ease } %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>
  </div>

  <div class="flex gap-4">
    <%= link_to "Study again", review_path, class: "px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
    <%= link_to "Back to tags", tags_path, class: "px-6 py-3 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600" %>
  </div>
</div>
