<div class="flex flex-col items-center justify-center min-h-64 text-center max-w-md mx-auto">
  <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-3">Session in progress</h2>
  <p class="text-gray-500 dark:text-gray-400 mb-8">
    You have an unfinished session with
    <span class="font-semibold text-gray-700 dark:text-gray-300"><%= @learning_session.card_count %></span>
    cards. Pick up where you left off?
  </p>

  <div class="flex gap-4">
    <%= link_to "Resume", review_resume_path,
          class: "px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors" %>
    <%= button_to "Start fresh", review_abandon_path,
          class: "px-6 py-3 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600
                  text-gray-700 dark:text-gray-200 font-semibold rounded-lg transition-colors" %>
  </div>
</div>
