<%
  entry    = @user_learning.dictionary_entry
  pinyin   = entry.meanings.first&.pinyin
  meanings = entry.meanings.reject { |m| m.text.start_with?("CL:") }
  shown    = meanings.first(3)
  overflow = meanings.size - shown.size
%>

<div class="flex flex-col items-center pt-8" data-controller="card-flip">

  <p class="text-sm text-gray-400 mb-6"><%= @position %> / <%= @total %></p>

  <%# ---- FRONT ---- %>
  <div data-card-flip-target="front">
    <div class="w-72 bg-white rounded-2xl shadow-lg flex items-center justify-center" style="height: 18rem;">
      <span class="text-9xl font-bold text-gray-900 select-none"><%= entry.text %></span>
    </div>

    <button data-action="click->card-flip#reveal"
            class="mt-6 w-72 py-3 bg-white border border-gray-200 rounded-xl text-gray-500 font-medium hover:bg-gray-50 transition-colors">
      Show answer
    </button>
  </div>

  <%# ---- BACK (hidden until revealed) ---- %>
  <div data-card-flip-target="back" class="hidden">
    <div class="flex flex-col items-center">
      <div class="w-72 bg-white rounded-2xl shadow-lg flex flex-col items-center justify-center px-8 py-10 text-center" style="min-height: 18rem;">
        <p class="text-3xl text-gray-400 mb-4"><%= pinyin %></p>
        <p class="text-xl font-medium text-gray-800"><%= shown.map(&:text).join(", ") %></p>
        <% if overflow > 0 %>
          <p class="mt-2 text-sm text-gray-400">and <%= overflow %> more</p>
        <% end %>
      </div>

      <div class="mt-6 grid grid-cols-4 gap-2 w-72">
        <%= button_to "Again", review_card_path, params: { ease: 1 },
              class: "py-3 bg-red-50 text-red-600 font-medium rounded-xl hover:bg-red-100 transition-colors" %>
        <%= button_to "Hard",  review_card_path, params: { ease: 2 },
              class: "py-3 bg-orange-50 text-orange-600 font-medium rounded-xl hover:bg-orange-100 transition-colors" %>
        <%= button_to "Good",  review_card_path, params: { ease: 3 },
              class: "py-3 bg-green-50 text-green-600 font-medium rounded-xl hover:bg-green-100 transition-colors" %>
        <%= button_to "Easy",  review_card_path, params: { ease: 4 },
              class: "py-3 bg-blue-50 text-blue-600 font-medium rounded-xl hover:bg-blue-100 transition-colors" %>
      </div>
    </div>
  </div>

</div>
