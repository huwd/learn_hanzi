<div class="flex-grow max-w-2xl mx-auto w-full">
  <h1 class="text-3xl font-bold text-gray-800 dark:text-gray-200 mb-2">Import Learning Data</h1>
  <p class="text-gray-500 dark:text-gray-400 mb-8">
    Restore from a previous export or migrate data from another account.
  </p>

  <% if flash[:notice] %>
    <div class="mb-6 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 p-4">
      <p class="text-sm text-green-700 dark:text-green-400"><%= flash[:notice] %></p>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="mb-6 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 p-4">
      <p class="text-sm text-red-700 dark:text-red-400"><%= flash[:alert] %></p>
    </div>
  <% end %>

  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-8">
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      Upload a <code class="font-mono text-indigo-600 dark:text-indigo-400">.json</code>
      file previously exported from this app.
      Existing records are updated only when the export is newer; review logs are
      never duplicated on re-import.
    </p>

    <%= form_with url: data_imports_path, multipart: true do |f| %>
      <div class="mb-6">
        <%= f.label :file, "Export file (.json)",
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.file_field :file,
              accept: ".json,application/json",
              class: "block w-full text-sm text-gray-500 dark:text-gray-400
                      file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0
                      file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700
                      hover:file:bg-indigo-100 dark:file:bg-indigo-900/30 dark:file:text-indigo-300
                      cursor-pointer" %>
        <p class="mt-2 text-xs text-gray-400">Maximum file size: 10 MB</p>
      </div>
      <%= f.submit "Import",
            class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg
                    px-6 py-3 transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
