<%
  total       = stats[:total].to_f
  mastered_w  = total > 0 ? (stats[:mastered]    / total * 100).round(1) : 0
  learning_w  = total > 0 ? (stats[:learning]    / total * 100).round(1) : 0
  new_w       = total > 0 ? (stats[:new_count]   / total * 100).round(1) : 0
%>
<div class="flex h-2 rounded-full overflow-hidden bg-gray-100">
  <% if mastered_w > 0 %>
    <div class="bg-green-500 transition-all" style="width: <%= mastered_w %>%"></div>
  <% end %>
  <% if learning_w > 0 %>
    <div class="bg-amber-400 transition-all" style="width: <%= learning_w %>%"></div>
  <% end %>
  <% if new_w > 0 %>
    <div class="bg-indigo-300 transition-all" style="width: <%= new_w %>%"></div>
  <% end %>
  <%# remaining grey is the bg-gray-100 background showing through %>
</div>
