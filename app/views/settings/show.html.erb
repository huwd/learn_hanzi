<div class="flex-grow max-w-4xl mx-auto w-full">
  <h1 class="text-3xl font-bold text-gray-800 dark:text-gray-200 mb-8">Settings</h1>

  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-8">
    <h2 class="text-xl font-semibold text-gray-700 dark:text-gray-300 mb-6">Session preferences</h2>

    <%= form_with model: @user, url: settings_path, method: :patch do |f| %>
      <% if @user.errors.any? %>
        <div class="mb-6 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 p-4">
          <p class="text-sm font-semibold text-red-700 dark:text-red-400 mb-2">
            Please fix the following errors:
          </p>
          <ul class="list-disc list-inside space-y-1 text-sm text-red-600 dark:text-red-400">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <%= f.label :session_size, "Session size",
                class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
            Maximum number of cards per review session (1–100).
          </p>
          <%= f.number_field :session_size, min: 1, max: 100,
                class: "w-32 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700
                        text-gray-900 dark:text-gray-100 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :new_cards_per_session, "New cards per session",
                class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
            How many unseen cards to introduce per session (must not exceed session size).
          </p>
          <%= f.number_field :new_cards_per_session, min: 0,
                class: "w-32 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700
                        text-gray-900 dark:text-gray-100 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>

      <div class="mt-8">
        <%= f.submit "Save settings",
              class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-6 py-3
                      transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-8 mt-8">
    <h2 class="text-xl font-semibold text-gray-700 dark:text-gray-300 mb-2">Your data</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      Export all your learning progress as a JSON file, or restore from a previous export.
    </p>
    <div class="flex flex-wrap gap-4">
      <%= link_to "Export data", data_export_path,
            class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-5 py-2.5
                    transition-colors text-sm" %>
      <%= link_to "Import data", new_data_import_path,
            class: "bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600
                    text-gray-700 dark:text-gray-300 font-semibold rounded-lg px-5 py-2.5
                    border border-gray-300 dark:border-gray-600 transition-colors text-sm" %>
    </div>
  </div>
</div>
