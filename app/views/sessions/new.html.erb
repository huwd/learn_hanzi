<% content_for :title, "Sign in" %>

<div class="max-w-sm mx-auto text-center py-16">
  <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4">Sign in to Learn Hanzi</h2>
  <p class="text-gray-500 dark:text-gray-400 mb-8">Sign in with your PocketID account to continue.</p>
  <%= button_to "/auth/oidc",
        class: "w-full px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-500 transition-colors" do %>
    Sign in with PocketID
  <% end %>
</div>
