<% content_for :title, "Authentication failed" %>

<div class="max-w-md mx-auto text-center py-16">
  <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4">Authentication failed</h2>
  <p class="text-gray-600 dark:text-gray-400 mb-8">Something went wrong signing you in. Please try again.</p>
  <%= link_to "Try again", oidc_login_path,
        class: "inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-500 transition-colors" %>
</div>
