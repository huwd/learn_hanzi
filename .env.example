# =============================================================================
# learn_hanzi — environment variable reference
# =============================================================================
# Copy this file to .env and fill in the values marked REQUIRED before
# starting the container. Variables marked OPTIONAL have safe defaults.
#
# NEVER commit your .env file — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Rails
# -----------------------------------------------------------------------------

# REQUIRED — decrypt Rails credentials (config/credentials.yml.enc).
# Find the value in config/master.key on a machine that has already been set up.
RAILS_MASTER_KEY=

# OPTIONAL — controls Rails log verbosity. Default: info
# Valid values: debug, info, warn, error, fatal
RAILS_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Image
# -----------------------------------------------------------------------------

# REQUIRED — the GitHub username or organisation that owns the GHCR package.
# The image is published to: ghcr.io/<GHCR_OWNER>/learn_hanzi
GHCR_OWNER=

# OPTIONAL — image tag to deploy. Default: latest
# Pin to a specific SHA digest (e.g. sha256:abc123) for reproducible deploys.
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------

# OPTIONAL — host port to bind. Default: 80
# Change this if port 80 is already in use on your host, then configure your
# reverse proxy or tunnel to forward traffic to this port.
PORT=80

# OPTIONAL — number of Puma worker processes. Default: 1
# Increase on hosts with multiple cores and sufficient RAM (each worker ~150 MB).
WEB_CONCURRENCY=1

# -----------------------------------------------------------------------------
# Storage / backups (optional but recommended for production)
# -----------------------------------------------------------------------------
# The app uses SQLite for all databases (primary, cache, queue, Anki import).
# All database files live inside the named Docker volume mounted at /rails/storage.
#
# For continuous off-host backup, run Litestream as a sidecar container and
# point it at the same volume. Litestream supports S3-compatible object stores
# (AWS S3, Backblaze B2, Cloudflare R2, MinIO, etc.).
#
# See: https://litestream.io/getting-started/
