# =============================================================================
# learn_hanzi — environment variable reference
# =============================================================================
# Copy this file to .env and fill in the values marked REQUIRED before
# starting the container. Variables marked OPTIONAL have safe defaults.
#
# NEVER commit your .env file — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Rails
# -----------------------------------------------------------------------------

# REQUIRED — decrypt Rails credentials (config/credentials.yml.enc).
# Find the value in config/master.key on a machine that has already been set up.
RAILS_MASTER_KEY=

# OPTIONAL — controls Rails log verbosity. Default: info
# Valid values: debug, info, warn, error, fatal
RAILS_LOG_LEVEL=info

# REQUIRED — the public hostname of the app (no protocol or trailing slash).
# Used for URL generation in mailers and action_mailer.default_url_options.
APP_HOST=

# OPTIONAL — the from address for outgoing emails. Default: noreply@example.com
MAILER_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Image
# -----------------------------------------------------------------------------

# REQUIRED — the GitHub username or organisation that owns the GHCR package.
# The image is published to: ghcr.io/<GHCR_OWNER>/learn_hanzi
GHCR_OWNER=

# OPTIONAL — image tag to deploy. Default: latest
# Pin to a specific tag (e.g. a short commit SHA like a1b2c3d) for reproducible
# deploys rather than floating on latest.
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------

# OPTIONAL — host port to bind. Default: 80
# The port exposed on the host that your reverse proxy or tunnel forwards to.
PORT=80

# OPTIONAL — internal container port Thruster listens on. Default: 3000
# Must be above 1024 if running as a non-root user (see CONTAINER_UID above).
# Change this if 3000 conflicts with another service on the same Docker network.
HTTP_PORT=3000

# OPTIONAL — number of Puma worker processes. Default: 1
# Increase on hosts with multiple cores and sufficient RAM (each worker ~150 MB).
WEB_CONCURRENCY=1

# -----------------------------------------------------------------------------
# Container user
# -----------------------------------------------------------------------------

# OPTIONAL — UID and GID the container process runs as. Defaults to 1000:1000
# (the Rails user created in the Dockerfile). Set these to match the owner of
# STORAGE_PATH on your host so the container can read and write the directory
# without requiring a chown. Find your UID/GID with: id
CONTAINER_UID=1000
CONTAINER_GID=1000
# Note: when CONTAINER_UID does not match the Rails user in the image (UID 1000),
# Bundler cannot find a HOME directory and logs a noisy warning. BUNDLE_USER_HOME
# is hardcoded to /tmp/bundler in docker-compose.yml to suppress this.

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# REQUIRED — absolute path on the host to mount as the app's storage directory.
# All SQLite databases (primary, cache, queue, Anki import) are stored here.
# The directory must exist and be writable before starting the container.
# Example: /path/to/your/storage
STORAGE_PATH=

# -----------------------------------------------------------------------------
# Backups (optional but recommended for production)
# -----------------------------------------------------------------------------
# All SQLite databases are stored at the host path set in STORAGE_PATH above.
# Back up that directory with any tool that can read the host filesystem.
#
# For continuous off-host backup, run Litestream as a sidecar container and
# point it at the same STORAGE_PATH. Litestream supports S3-compatible object
# stores (AWS S3, Backblaze B2, Cloudflare R2, MinIO, etc.).
#
# See: https://litestream.io/getting-started/
